VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Resend — transactional email provider for auth confirmation emails.
# Used by the supabase/functions/send-email Edge Function.
# Set these as Supabase Edge Function secrets (not as Vite env vars):
#   supabase secrets set RESEND_API_KEY=re_... RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@sharedxp.com

# Shared secret used to verify requests from the Supabase Send Email auth hook.
# Generate with: openssl rand -hex 32
# Set as a Supabase Edge Function secret:
#   supabase secrets set SEND_EMAIL_HOOK_SECRET=your-secret
SEND_EMAIL_HOOK_SECRET=your-send-email-hook-secret
